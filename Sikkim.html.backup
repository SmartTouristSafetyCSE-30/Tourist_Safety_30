<script type="text/javascript">
    $(document).ready(function () {
              $(window).scroll(function () {
            if ($(this).scrollTop() > 100) {
                $('#scroll').fadeIn();
            } else {
                $('#scroll').fadeOut();
            }
        });
        $('#scroll').click(function () {
            $("html, body").animate({ scrollTop: 0 }, 800);
            return false;
        });

    });
    $("#thingsToDoCarousel").owlCarousel({
        loop: true,
        margin: 10,
        autoplay: true,
        autoplayTimeout: 5000,
        autoplayHoverPause: true,
        autoHeight: true,
        responsiveClass: true,
        responsive: {
            0: {
                items: 2,
                nav: false,
            },
            600: {
                items: 3,
            },
            1000: {
                items: 4,
                margin: 20
            }
        },
        dots: false,
        nav: false,
        navText: ["<i class='fas fa-caret-left'></i>", "<i class='fas fa-caret-right'></i>"]
    });
    $('.carousel').carousel({
        interval: 5000
    })
    $("#accomodationListDiv").owlCarousel({
        loop: true,
        margin: 10,
        autoplay: true,
        autoplayTimeout: 5000,
        autoplayHoverPause: true,
        autoHeight: true,
        responsiveClass: true,
        responsive: {
            0: {
                items: 1,
                nav: false,
            },
            600: {
                items: 2,
            },
            1000: {
                items: 3,
                margin: 20
            }
        },
        dots: false,
        nav: true,
        navText: ['<i class="fa fa-angle-left navLeftArrowAcc" aria-hidden="true"></i>', '<i class="fa fa-angle-right navRightArrowAcc" aria-hidden="true"></i>']
    });
    $('.panel-collapse').on('show.bs.collapse', function () {
        $(this).siblings('.panel-heading').addClass('active');
    });

    $('.panel-collapse').on('hide.bs.collapse', function () {
        $(this).siblings('.panel-heading').removeClass('active');
    });
    function getThingsToDoDetails(type) {
        if (type != $('#thingsToDoTitle').text()) {
            $.ajax({
                url: '/Public/Index/GetThingsToDoDetails',
                type: 'GET',
                data: { type: type },
                success: function (data) {
                    $('#thingsToDoDetailsDiv').html(data);
                }
            })
        }
    }
    $("#ContactUsBtn").click(function () {
        $('html,body').animate({
            scrollTop: $("#ContactUsDiv").offset().top
        },
            1000);
    });

    $(".complain-button").click(function () {
        $('html,body').animate({
            scrollTop: $("#ContactUsDiv").offset().top
        },
            1000);
    });


    function displayImageInNewTab(imgSrc) {
        var image = new Image();
        image.src = imgSrc;

        var w = window.open("");
        w.document.write(image.outerHTML);
    }

    $('#newsevent').on('click', function () {
        var Id = $(this).attr("data-id");
        $.ajax({
            type: "GET",
            url: "/Public/Index/GetNewsEventDetails",
            data: { ID: Id },
            success: function (response) {
                $('#newsEventDetails').html(response);
            },
            failure: function (response) {
            },
            error: function (response) {
                $('#newsEventDetails').html(response);
            }
        });
    });

</script>

