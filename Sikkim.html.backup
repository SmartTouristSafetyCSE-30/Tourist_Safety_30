    <div class="modal fade modal-fullscreen pr-0" id="searchModal" tabindex="-1" role="dialog" aria-labelledby="myModalLabel">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header border-0">
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                </div>
                <div class="modal-body">
                    <div class="container">
                        <div class="col-12 pl-0 border-bottom">
                            <div class="row">
                                <div class="col-10">
                                    <input type="text" placeholder="Enter a search term" class="searchInput w-100" id="searchInput" />
                                </div>
                                <div class="col-2 pr-0 d-flex justify-content-end align-items-center">
                                    <a href="javascript:void(0);" id="searchResultBtn" class="pr-0 btn btn-lg btn-link color--theme--link text-decoration-none disabled" disabled>Search</a>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 mt-3" id="loader" style="display:none;">
                            <div class="spinner-border" role="status"><span class="sr-only">Loading...</span></div>
                        </div>
                        <div id="searchPartialView" class="col-12 mt-4">
                            <div class="row searchList">
    <div class="col-12 searchList__Item">
        Unfortunately we could not find any results.
        Check the spelling of the entered words, try different keywords or try more general keywords
    </div>
</div>

                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0">
            </div>
        </div>
    </div>
    <div id="ModalFeedbackWithScreenShot"></div>
    <script type="text/javascript">
         $(document).ready(function () {
            var isSafari = /constructor/i.test(window.HTMLElement) || (function (p) { return p.toString() === "[object SafariRemoteNotification]"; })(!window['safari'] || (typeof safari !== 'undefined' && safari.pushNotification));
            var userAgentString = navigator.userAgent;
            console.log(isSafari)
            if (isSafari) {
                window.location.replace("/Error/CompatibilityIssue");
            }
            $(window).scroll(function () {
                if ($(this).scrollTop() > 100) {
                    $('#scroll').fadeIn();
                } else {
                    $('#scroll').fadeOut();
                }
            });
            $('#scroll').click(function () {
                $("html, body").animate({ scrollTop: 0 }, 800);
                return false;
            });
         });

        document.getElementById('searchInput').addEventListener('keyup', debounce(function () {
            $('#searchPartialView').removeClass('isafterLoaded--js');
            $('#searchPartialView').addClass('isUnloaded--js');
            $('#searchResultBtn').attr('disabled', 'disabled');
            $('#searchResultBtn').addClass('disabled');
            if ($('#searchInput').val().length >= 2) {
                $('#searchResultBtn').removeAttr('disabled');
                $('#searchResultBtn').removeClass('disabled');
                $('#loader').css('display', 'block');
                $('#loader').addClass('d-flex');
                $('#loader').addClass('justify-content-center');
                $.ajax({
                    url: '/Public/Index/GetSearchResult',
                    type: 'GET',
                    data: { searchTerm: $('#searchInput').val() },
                    success: function (data) {
                        $('#searchPartialView').removeClass('isUnloaded--js');
                        $('#searchPartialView').addClass('isafterLoaded--js');
                        $('#loader').css('display', 'none');
                        $('#loader').removeClass('d-flex');
                        $('#loader').removeClass('justify-content-center');
                        $('#searchPartialView').html(data);
                        $('.searchList__List').fadeTo("slow", 1);
                        $('.searchList__Item').fadeTo("slow", 1);
                    }
                })
            }
        }, 1500)
        );

        $('#searchResultBtn').on('click', function () {
            if ($('#searchInput').val().length >= 2) {
                window.location.href = '/Public/Index/AllSearchResult?searchTerm=' + $('#searchInput').val();
            }
        })

        $('a.js-scroll-trigger[href*="#"]:not([href="#"])').click(function () {
            if (location.pathname.replace(/^\//, '') == this.pathname.replace(/^\//, '') && location.hostname == this.hostname) {
                var target = $(this.hash);
                target = target.length ? target : $('[name=' + this.hash.slice(1) + ']');
                if (target.length) {
                    $('html, body').animate({
                        scrollTop: (target.offset().top - 90)
                    }, 1000, "easeInOutExpo");
                    return false;
                }
            }
            $('#navbarOrg').removeClass('show');
        });
        $('body').scrollspy({
            target: '#navbarWrapper',
            offset: 100
        });

        $('#specificFeed').on('click', function () {
            $('#feedbackSecondModal').modal('show')
        });

        $('#directFeedback').on('click', function () {
            $('#genericFeedbackModal').modal('show')
        });

        $('#feedbackSecondModal').on('shown.bs.modal', function () {
            setTimeout(function () {
                $('#feedbackSecondModal').modal('hide');
                genScreenshot();
            }, 2000);
        })


        $('#closeFeedbackSuccess').on('click', function () {
            window.location.reload();
        })
        function getMouse(movedByMouse, left, top, width, height) {
            var t = movedByMouse;
            return relativeMouse = {
                x: (t.x - left) / width,
                y: (t.y - top) / height
            },
            {
                x: relativeMouse.x,
                y: relativeMouse.y,
                left: relativeMouse.x,
                top: relativeMouse.y
            }
        }
        $('[data-toggle="popover"]').popover();
        $('[data-toggle="tooltip"]').tooltip();
        $(".places").mouseover(function () {
            $('#mapImg').attr('src', $(this).attr("data-hover"));
        }).mouseout(function () {
            $('#mapImg').attr('src', $(this).attr("data-src"));
        });
        const headerEl = document.querySelector('#navbarWrapper')
        const sentinalEl = document.querySelector('#videoNav')
        const handler = (entries) => {
            if (!entries[0].isIntersecting) {
    headerEl.classList.add('enabled')
        } else {
    headerEl.classList.remove('enabled')
        }
        }
        // create the observer
const observer = new window.IntersectionObserver(handler)
        // give the observer some dom nodes to keep an eye on
observer.observe(sentinalEl)
        function openNav() {
            document.getElementById("mySidenav").style.width = "70vw";
            $('.sidenavShadow').show();
        }

        function closeNav() {
            document.getElementById("mySidenav").style.width = "0";
            $('.sidenavShadow').hide();
        }

        $('.sidenavShadow').on('click',function(){
            document.getElementById("mySidenav").style.width = "0";
            $('.sidenavShadow').hide();
        })

        function viewSubMenu(submenu){
            $('#'+ submenu).show();
            $('.mainMenuListDiv').hide();
        }

        function closeSubMenu(submenu){
            document.getElementById(submenu).style.display = "none";
            $('.mainMenuListDiv').show();
        }

        function viewSub_SuvbMenu(submenu,menu){
            $('#'+submenu).show();
            $('#'+menu).hide();
        }

        function closeSub_SubMenu(submenu,menu){
            $('#'+submenu).hide();
            $('#'+menu).show();
        }
    </script>

    <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
    <script>
        $(document).ready(function () {
            // Show hide popover
            $(".customdropdown").click(function () {
                $(this).find(".dd-menu").slideToggle("fast");
            });
        });
        $(document).on("click", function (event) {
            var $trigger = $(".customdropdown");
            if ($trigger !== event.target && !$trigger.has(event.target).length) {
                $(".dd-menu").slideUp("fast");
            }
        });
    </script>
    

    
