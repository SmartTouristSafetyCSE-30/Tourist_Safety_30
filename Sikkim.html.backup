<div class="modal fade" id="TravelCardModal" tabindex="-1" role="dialog" aria-labelledby="TravelCardModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-body p-1">
                <div class="col-12 text-center pt-2">
                    <img src="/Content/Pics/sikkimtourism-logo.png" style="height:65px" /><br />
                    <span class="" style="color: #666565; font-size: 20px; font-weight: 700">Sikkim Travel Card</span>
                </div>
                <div class="col-12 mt-3 mb-3">
                    <div class="row">
                        <div class="col-12 col-md-6 col-lg-6 mt-2 mt-sm-2 mt-md-2 mt-lg-0 ">
                            <div class="card cardHoverEffect" id="registerCard">
                                <a href="/Public/PublicMandates/TravellingMandates" class="text-decoration-none">
                                    <div class="card-body col-12">
                                        <div class="col-12 text-center">
                                            <h4 class="text-white" style="font-size:20px;">Apply for Travel Card</h4>
                                        </div>
                                        <div class="row">
                                            <div class="col-4 my-auto col-md-3 col-lg-2 text-white">
                                                <i class="fas fa-3x fa-users" style="font-size:38px"></i>
                                            </div>
                                            <div class="col-8 col-md-9 col-lg-10 text-white my-auto">
                                                <p class="text-justify mb-0" style="font-size:12px;">You are applying for a Travel Card yourself or assisting an individual or group.</p>
                                            </div>
                                        </div>
                                    </div>
                                </a>
                            </div>
                        </div>
                        <div class="col-12 col-md-6 col-lg-6 mt-2 mt-sm-2 mt-md-2 mt-lg-0 mt-xl-0">
                            <div class="card cardHoverEffect" id="updateCard">
                                <a href="/Public/PublicMandates/UpdateSubmission" class="text-decoration-none">
                                    <div class="card-body col-12">
                                        <div class="col-12 text-center">
                                            <h4 class="text-white" style="font-size:20px;">Update Travel Card</h4>
                                        </div>
                                        <div class="row">
                                            <div class="col-4 my-auto col-md-3 col-lg-2 text-white">
                                                <i class="fas fa-3x fa-edit" style="font-size:38px"></i>
                                            </div>
                                            <div class="col-8 col-md-9 col-lg-10 text-white my-auto pr-1">
                                                <p class="text-justify mb-0" style="font-size:12px;">You have already acquired a card for an upcoming trip and you want to update the information.</p>
                                            </div>
                                        </div>
                                    </div>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
