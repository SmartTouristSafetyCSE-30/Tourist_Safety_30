<section id="OrchidariumWelcome">
    <div class="container-custom my-5">
        <div class="row justify-content-center">
            <div class="col-12 text-center">
                <h3 class="mb-4 HD-4x" style="color: #3E3E3E; font-weight: 600">
                    Warm Welcome to the Orchidarium at Swarna Jyanti Maitreya Manjari, Ridge Park!
                </h3>
            </div>

            <!-- Video Section -->
            <div class="col-md-10 col-lg-8 mb-4">
                <div class="ratio ratio-16x9 shadow-sm rounded">
                    <!-- Replace src with your actual video URL -->
                    <video autoplay muted controls playsinline class="w-100 rounded shadow-sm" controls="controls">
                        <source src="/Content/Videos/OrchidariumWelcome.mp4" type="video/mp4" />
                        Your browser does not support the video tag.
                    </video>
                </div>
            </div>

            <!-- Content Section -->
            <div class="col-md-10 col-lg-8">
                <div class="card shadow-sm rounded-3 border-0 p-4" style="background: #f9f9f9;">
                    <div class="card-body">
                        <p class="mb-3" style="color: #444; font-size: 1rem; line-height: 1.6;">
                            On behalf of the <strong>Government of Sikkim</strong>, we heartily invite and welcome
                            local residents and tourists to explore the Orchidarium, a unique hub of orchid diversity
                            and beauty. Inaugurated by the <strong>Honorable Prime Minister</strong> on
                            <strong>May 29, 2025</strong>, virtually, the Orchidarium is now open to the public from
                            <strong>September 17, 2025</strong>.
                        </p>

                        <h5 class="mt-3" style="color: #3E3E3E; font-weight: 600;">Experience the Beauty of Orchids</h5>
                        <ul class="text-start" style="color:#444; font-size: 0.95rem; line-height:1.6;">
                            <li>Discover a wide range of native and exotic orchid species in a serene natural setting</li>
                            <li>Enjoy a hassle-free experience with our QR-based entry system, promoting digital convenience and transparency</li>
                        </ul>

                        <h5 class="mt-3" style="color: #3E3E3E; font-weight: 600;">Special Offer</h5>
                        <ul class="text-start" style="color:#444; font-size: 0.95rem; line-height:1.6;">
                            <li>Complimentary entry for Senior Citizens and Gurujis accompanying esteemed tourists</li>
                        </ul>

                        <h5 class="mt-3" style="color: #3E3E3E; font-weight: 600;">Visit Us</h5>
                        <p style="color:#444; font-size: 0.95rem; line-height:1.6;">
                            <strong>Timing:</strong> 11:00 AM to 6:00 PM <br>
                            <strong>Entry System:</strong> QR-based for a seamless experience
                        </p>

                        <p class="mt-4" style="color:#3E3E3E; font-size: 0.95rem;">
                            Join us in celebrating the spirit of eco-tourism and explore the wonders of the Orchidarium at
                            <strong>Swarna Jyanti Maitreya Manjari</strong>. We look forward to welcoming you!
                        </p>

                        <p class="fw-bold text-center mt-3" style="color:#444;">
                            Government of Sikkim <br>
                            <span style="font-weight: 500;">Management of Swarna Jyanti Maitreya Manjari</span>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>



