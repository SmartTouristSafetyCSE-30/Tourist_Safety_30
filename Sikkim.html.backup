<section id="SikkimHeritageWalk">
    <div class="container-custom my-5">
        <div class="my-4 mb-5 row m-0">
            <div class="col-12">
                <h3 class="text-center mb-5 HD-4x" style="color: #3E3E3E; font-weight: 600">Heritage Walk</h3>
            </div>

            <div id="heritageCarousel" class="carousel slide carousel-fade" data-bs-ride="carousel">

                <!-- Indicators (dots) -->
                <div class="carousel-indicators">
                    <button type="button" data-bs-target="#heritageCarousel" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Gangtok"></button>
                    <button type="button" data-bs-target="#heritageCarousel" data-bs-slide-to="1" aria-label="Gyalshing"></button>
                    <button type="button" data-bs-target="#heritageCarousel" data-bs-slide-to="2" aria-label="Perbing"></button>
                </div>

                <div class="carousel-inner">
                    <div class="carousel-item active">
                        <img src="/Content/NewIndexPhotos/gangtok-heritage-walk.jpeg" class="d-block w-100 rounded img-fluid" alt="Gangtok Heritage Walk Image">
                    </div>
                    <div class="carousel-item">
                        <img src="/Content/NewIndexPhotos/gyalshing-heritage-walk.jpeg" class="d-block w-100 rounded img-fluid" alt="Gyalshing Heritage Walk Image">
                    </div>
                    <div class="carousel-item">
                        <img src="/Content/NewIndexPhotos/perbing-heritage-walk.jpeg" class="d-block w-100 rounded img-fluid" alt="Perbing Heritage Walk Image">
                    </div>
                </div>

                <!-- Prev & Next with dark background -->
                <button class="carousel-control-prev" type="button" data-bs-target="#heritageCarousel" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon" style="background-color: rgba(0,0,0,0.5); border-radius: 50%; padding: 8px; width: 28px; height: 28px; background-size: 60% 60%; " aria-hidden="true"></span>
                    <span class="visually-hidden">Previous</span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#heritageCarousel" data-bs-slide="next">
                    <span class="carousel-control-next-icon" style="background-color: rgba(0,0,0,0.5); border-radius: 50%; padding: 8px; width: 28px; height: 28px; background-size: 60% 60%; " aria-hidden="true"></span>
                    <span class="visually-hidden">Next</span>
                </button>
            </div>
        </div>
    </div>
</section>


<section id="DiscoverSikkim">
    <div class="col-12">
        <h3 class="text-center mb-5 HD-4x" style="color: #3E3E3E; font-weight: 600">Discover Sikkim</h3>
        <div class="row clearfix">
            <div class="col-6 col-md-3 px-1">
                <a href="/Public/ThingsToDo/Pilgrimage" target="_blank">
                    <div style="position:relative;height:100%">
                        
                        <img class="discover-image" src="/Content/NewIndexPhotos/rumtek_monastery.jpeg" alt="Card image cap">
                        <div class="cardOverLayDiv">
                            <div class="cardOverlayTitle">
                                <p class="HD-1x font-weight-bold">Monastries &nbsp;<i class="fa fa-arrow-right" style="font-size:12px"></i></p>
                                <p class="PARA-2x text-white">Visit many monastries in Sikkim...</p>
                            </div>
                        </div>
                    </div>
                </a>

            </div>
            <div class="col-6 col-md-3 px-1">
