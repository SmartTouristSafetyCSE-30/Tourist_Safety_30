<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>About North East India - Smart Tourist Safety System</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body { 
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; 
            line-height: 1.6; 
            color: #333; 
            background: #f0f4f8;
        }
        
        .skip-link { 
            position: absolute; 
            top: -40px; 
            left: 6px; 
            background: #000; 
            color: #fff; 
            padding: 8px; 
            text-decoration: none; 
            z-index: 1000; 
        }
        .skip-link:focus { top: 6px; }
        
        /* Top Info Bar */
        .top-bar {
            background: #001f3f;
            color: white;
            padding: 8px 0;
            font-size: 13px;
        }
        
        .top-bar-content {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .top-links a {
            color: white;
            text-decoration: none;
            margin-left: 20px;
            transition: color 0.3s;
        }
        
        .top-links a:hover {
            color: #ff9933;
        }
        
        /* Main Header */
        .gov-header { 
            background: linear-gradient(135deg, #ff6600 0%, #ff8533 50%, #ff9933 100%); 
            color: white; 
            padding: 20px 0;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }
        
        .header-top { 
            display: flex; 
            justify-content: space-between; 
            align-items: center; 
            max-width: 1200px; 
            margin: 0 auto; 
            padding: 0 20px; 
        }
        
        .logo-section { 
            display: flex; 
            align-items: center; 
            gap: 20px; 
        }
        
        .emblem { 
            width: 70px; 
            height: 70px; 
            background: white; 
            border-radius: 50%; 
            display: flex; 
            align-items: center; 
            justify-content: center; 
            font-size: 36px;
            box-shadow: 0 3px 10px rgba(0,0,0,0.2);
            border: 3px solid #ffe0cc;
        }
        
        .site-title { 
            font-size: 28px; 
            font-weight: bold; 
            text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
        }
        
        .site-subtitle { 
            font-size: 14px; 
            opacity: 0.95; 
            margin-top: 4px;
        }
        
        .sdg-badge {
            background: rgba(255,255,255,0.2);
            padding: 4px 10px;
            border-radius: 12px;
            font-size: 11px;
            margin-top: 5px;
            display: inline-block;
            border: 1px solid rgba(255,255,255,0.3);
        }
        
        .accessibility-controls { 
            display: flex; 
            gap: 15px; 
            align-items: center; 
        }
        
        .font-controls {
            background: rgba(255,255,255,0.15);
            padding: 5px;
            border-radius: 5px;
            display: flex;
            gap: 5px;
        }
        
        .font-controls button { 
            background: rgba(255,255,255,0.9); 
            border: none; 
            color: #ff6600; 
            padding: 6px 12px; 
            border-radius: 4px; 
            cursor: pointer;
            font-weight: bold;
            transition: all 0.3s;
        }
        
        .font-controls button:hover {
            background: white;
            transform: scale(1.1);
        }
        
        .lang-selector select { 
            background: rgba(255,255,255,0.9); 
            border: none; 
            color: #ff6600; 
            padding: 8px 12px; 
            border-radius: 4px; 
            cursor: pointer;
            font-weight: 600;
        }
        
        /* Navigation */
        .main-nav { 
            background: linear-gradient(to right, #003366, #004080);
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }
        
        .nav-container { 
            max-width: 1200px; 
            margin: 0 auto; 
        }
        
        .nav-menu { 
            display: flex; 
            list-style: none; 
        }
        
        .nav-menu li a { 
            display: block; 
            padding: 16px 24px; 
            color: white; 
            text-decoration: none; 
            transition: all 0.3s;
            font-weight: 500;
            position: relative;
        }
        
        .nav-menu li a::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 50%;
            width: 0;
            height: 3px;
            background: #ff9933;
            transition: all 0.3s;
            transform: translateX(-50%);
        }
        
        .nav-menu li a:hover {
            background: rgba(255,255,255,0.1);
        }
        
        .nav-menu li a:hover::after {
            width: 80%;
        }
        
        /* Main Content */
        .main-content { 
            max-width: 1200px; 
            margin: 0 auto; 
            padding: 30px 20px; 
        }
        
        /* Hero Section */
        .hero-section {
            background: linear-gradient(135deg, rgba(0,51,102,0.95), rgba(0,64,128,0.95)), 
                        url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 400"><rect fill="%23e3f2fd" width="1200" height="400"/><g opacity="0.5"><circle cx="100" cy="100" r="40" fill="%2390caf9"/><circle cx="300" cy="150" r="30" fill="%2364b5f6"/><circle cx="500" cy="80" r="50" fill="%2342a5f5"/><circle cx="700" cy="120" r="35" fill="%2390caf9"/><circle cx="900" cy="90" r="45" fill="%2364b5f6"/><circle cx="1100" cy="140" r="38" fill="%2342a5f5"/></g></svg>');
            background-size: cover;
            background-position: center;
            color: white;
            padding: 50px;
            border-radius: 15px;
            margin-bottom: 40px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        }
        
        .page-title { 
            font-size: 42px; 
            margin-bottom: 15px;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
        }
        
        .page-subtitle {
            font-size: 18px;
            opacity: 0.95;
            margin-bottom: 20px;
        }
        
        .breadcrumb { 
            color: rgba(255,255,255,0.9);
            font-size: 14px;
        }
        
        .breadcrumb a {
            color: #ff9933;
            text-decoration: none;
        }
        
        /* Content Sections */
        .content-section { 
            background: white;
            padding: 35px;
            border-radius: 12px;
            margin-bottom: 30px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.08);
        }
        
        .section-title { 
            font-size: 28px; 
            color: #003366; 
            margin-bottom: 20px;
            padding-bottom: 10px;
            border-left: 5px solid #ff6600;
            padding-left: 15px;
        }
        
        .intro-text {
            font-size: 16px;
            color: #555;
            margin-bottom: 25px;
            line-height: 1.8;
        }
        
        /* States Grid */
        .states-grid { 
            display: grid; 
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); 
            gap: 25px; 
            margin: 20px 0; 
        }
        
        .state-card { 
            background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
            border: 2px solid #e0e7ee;
            border-radius: 12px; 
            padding: 25px; 
            transition: all 0.3s;
            position: relative;
            overflow: hidden;
        }
        
        .state-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 5px;
            background: linear-gradient(to right, #ff6600, #ff9933);
            transform: scaleX(0);
            transition: transform 0.3s;
        }
        
        .state-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 12px 25px rgba(0,0,0,0.15);
            border-color: #ff9933;
        }
        
        .state-card:hover::before {
            transform: scaleX(1);
        }
        
        .state-name { 
            font-size: 22px; 
            font-weight: bold; 
            color: #003366; 
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .state-name span {
            font-size: 28px;
        }
        
        .state-info { 
            color: #666;
            line-height: 1.8;
        }
        
        .state-info strong {
            color: #003366;
            font-weight: 600;
        }
        
        /* Safety Initiatives */
        .initiatives-list {
            list-style: none;
            margin: 20px 0;
        }
        
        .initiatives-list li {
            padding: 15px 20px;
            margin-bottom: 12px;
            background: linear-gradient(to right, #e3f2fd, #f8f9fa);
            border-left: 4px solid #ff6600;
            border-radius: 6px;
            transition: all 0.3s;
        }
        
        .initiatives-list li:hover {
            background: linear-gradient(to right, #bbdefb, #e3f2fd);
            transform: translateX(10px);
        }
        
        .initiatives-list li::before {
            content: '✓';
            color: #ff6600;
            font-weight: bold;
            margin-right: 10px;
            font-size: 18px;
        }
        
        /* Stats Section */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin: 30px 0;
        }
        
        .stat-card {
            background: linear-gradient(135deg, #003366, #004080);
            color: white;
            padding: 25px;
            border-radius: 10px;
            text-align: center;
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        }
        
        .stat-number {
            font-size: 36px;
            font-weight: bold;
            margin-bottom: 10px;
            color: #ff9933;
        }
        
        .stat-label {
            font-size: 14px;
            opacity: 0.9;
        }
        
        /* Footer */
        .gov-footer { 
            background: linear-gradient(to right, #001f3f, #003366);
            color: white; 
            padding: 50px 0 20px; 
            margin-top: 60px;
        }
        
        .footer-content { 
            max-width: 1200px; 
            margin: 0 auto; 
            padding: 0 20px;
        }
        
        .footer-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 30px;
            margin-bottom: 30px;
        }
        
        .footer-section h3 {
            color: #ff9933;
            margin-bottom: 15px;
            font-size: 18px;
        }
        
        .footer-section ul {
            list-style: none;
        }
        
        .footer-section ul li {
            margin-bottom: 8px;
        }
        
        .footer-section a {
            color: rgba(255,255,255,0.8);
            text-decoration: none;
            transition: color 0.3s;
        }
        
        .footer-section a:hover {
            color: #ff9933;
        }
        
        .footer-bottom {
            border-top: 1px solid rgba(255,255,255,0.2);
            padding-top: 20px;
            text-align: center;
            color: rgba(255,255,255,0.7);
        }
        
        /* Responsive */
        @media (max-width: 768px) {
            .header-top { flex-direction: column; gap: 15px; text-align: center; }
            .nav-menu { flex-direction: column; }
            .states-grid { grid-template-columns: 1fr; }
            .page-title { font-size: 32px; }
            .hero-section { padding: 30px 20px; }
            .top-bar-content { flex-direction: column; gap: 10px; text-align: center; }
            .top-links a { margin: 0 10px; }
        }
    </style>
</head>
<body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    
    <!-- Top Info Bar -->
    <div class="top-bar">
        <div class="top-bar-content">
            <div>🇮🇳 Government of India | Ministry of Development of North Eastern Region</div>
            <div class="top-links">
                <a href="#">Screen Reader</a>
                <a href="#">Sitemap</a>
                <a href="#">Help</a>
            </div>
        </div>
    </div>
    
    <!-- Main Header -->
    <header class="gov-header">
        <div class="header-top">
            <div class="logo-section">
                <div class="emblem">🇮🇳</div>
                <div>
                    <div class="site-title">Smart Tourist Safety System</div>
                    <div class="site-subtitle">Ministry of Development of North Eastern Region</div>
                    <div class="sdg-badge">SDG-9: Industry, Innovation & Infrastructure</div>
                </div>
            </div>
            <div class="accessibility-controls">
                <div class="font-controls">
                    <button onclick="changeFontSize(-1)" aria-label="Decrease font size">A-</button>
                    <button onclick="changeFontSize(0)" aria-label="Reset font size">A</button>
                    <button onclick="changeFontSize(1)" aria-label="Increase font size">A+</button>
                </div>
                <select class="lang-selector" aria-label="Select language">
                    <option value="en">English</option>
                    <option value="hi">हिंदी</option>
                </select>
            </div>
        </div>
    </header>
    
    <!-- Navigation -->
    <nav class="main-nav">
        <div class="nav-container">
            <ul class="nav-menu">
                <li><a href="index.html">Home</a></li>
                <li><a href="about-north-east.html">About North East</a></li>
                <li><a href="departments.html">Departments</a></li>
                <li><a href="services.html">Services</a></li>
                <li><a href="contact.html">Contact</a></li>
            </ul>
        </div>
    </nav>
    
    <!-- Main Content -->
    <main id="main-content" class="main-content">
        <!-- Hero Section -->
        <div class="hero-section">
            <h1 class="page-title">Discover North East India</h1>
            <p class="page-subtitle">Explore the rich cultural heritage and natural beauty of India's Eastern Himalayas</p>
            <div class="breadcrumb"><a href="index.html">Home</a> > About North East India</div>
        </div>
        
        <!-- Stats Section -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-number">8</div>
                <div class="stat-label">States</div>
            </div>
            <div class="stat-card">
                <div class="stat-number">45M+</div>
                <div class="stat-label">Population</div>
            </div>
            <div class="stat-card">
                <div class="stat-number">200+</div>
                <div class="stat-label">Tribal Groups</div>
            </div>
            <div class="stat-card">
                <div class="stat-number">24/7</div>
                <div class="stat-label">Safety Support</div>
            </div>
        </div>
        
        <!-- States Section -->
        <section class="content-section">
            <h2 class="section-title">The Eight Sister States</h2>
            <p class="intro-text">North East India comprises eight states, collectively known as the "Seven Sisters" plus Sikkim. This enchanting region is renowned for its extraordinary cultural diversity, breathtaking natural landscapes, and strategic geographical importance. Each state offers unique experiences, from ancient monasteries to vibrant festivals.</p>
            
            <div class="states-grid">
                <div class="state-card">
                    <div class="state-name"><span>🏔️</span> Assam</div>
                    <div class="state-info">
                        <strong>Capital:</strong> Dispur<br>
                        <strong>Famous for:</strong> World-renowned tea gardens, Kaziranga National Park (one-horned rhinos), mighty Brahmaputra River, and rich Assamese culture
                    </div>
                </div>
                
                <div class="state-card">
                    <div class="state-name"><span>🌧️</span> Meghalaya</div>
                    <div class="state-info">
                        <strong>Capital:</strong> Shillong<br>
                        <strong>Famous for:</strong> Living root bridges, wettest place on Earth (Cherrapunji), mysterious caves, and Scotland of the East
                    </div>
                </div>
                
                <div class="state-card">
                    <div class="state-name"><span>🏛️</span> Manipur</div>
                    <div class="state-info">
                        <strong>Capital:</strong> Imphal<br>
                        <strong>Famous for:</strong> Loktak Lake (floating islands), classical dance forms, martial arts, and exquisite handloom traditions
                    </div>
                </div>
                
                <div class="state-card">
                    <div class="state-name"><span>🎭</span> Nagaland</div>
                    <div class="state-info">
                        <strong>Capital:</strong> Kohima<br>
                        <strong>Famous for:</strong> Spectacular Hornbill Festival, diverse tribal heritage, vibrant handicrafts, and warrior culture
                    </div>
                </div>
                
                <div class="state-card">
                    <div class="state-name"><span>🎵</span> Mizoram</div>
                    <div class="state-info">
                        <strong>Capital:</strong> Aizawl<br>
                        <strong>Famous for:</strong> Picturesque Blue Mountain, traditional Cheraw bamboo dance, peaceful society, and lush green landscapes
                    </div>
                </div>
                
                <div class="state-card">
                    <div class="state-name"><span>🏰</span> Tripura</div>
                    <div class="state-info">
                        <strong>Capital:</strong> Agartala<br>
                        <strong>Famous for:</strong> Majestic Ujjayanta Palace, Neermahal water palace, rich tribal heritage, and handicrafts
                    </div>
                </div>
                
                <div class="state-card">
                    <div class="state-name"><span>🌄</span> Arunachal Pradesh</div>
                    <div class="state-info">
                        <strong>Capital:</strong> Itanagar<br>
                        <strong>Famous for:</strong> Tawang Monastery (India's largest), first sunrise point, pristine monasteries, and diverse indigenous communities
                    </div>
                </div>
                
                <div class="state-card">
                    <div class="state-name"><span>⛰️</span> Sikkim</div>
                    <div class="state-info">
                        <strong>Capital:</strong> Gangtok<br>
                        <strong>Famous for:</strong> Kanchenjunga (third highest peak), Buddhist monasteries, 100% organic farming state, and adventure tourism
                    </div>
                </div>
            </div>
        </section>
        
        <!-- Safety Initiatives Section -->
        <section class="content-section">
            <h2 class="section-title">Comprehensive Tourist Safety Initiatives</h2>
            <p class="intro-text">The Ministry of Development of North Eastern Region (MoDoNER) has launched a cutting-edge Smart Tourist Safety System to ensure the security and wellbeing of all visitors exploring the beautiful North East. Our comprehensive framework integrates technology, local expertise, and emergency response mechanisms.</p>
            
            <ul class="initiatives-list">
                <li><strong>Digital Tourist ID System:</strong> Secure digital identification for all visitors ensuring quick verification and assistance</li>
                <li><strong>24/7 Emergency Response Network:</strong> Round-the-clock support through integrated helplines and rapid response teams</li>
                <li><strong>Real-time GPS Tracking:</strong> Advanced monitoring systems for trekker and tourist safety in remote areas</li>
                <li><strong>Multilingual Support Services:</strong> Assistance available in multiple languages including English, Hindi, and regional dialects</li>
                <li><strong>Integrated Police Network:</strong> Seamless coordination with state police and tourism departments across all eight states</li>
                <li><strong>Mobile Safety App:</strong> User-friendly application with SOS features, location sharing, and instant emergency alerts</li>
            </ul>
        </section>
    </main>
    
    <!-- Footer -->
    <footer class="gov-footer">
        <div class="footer-content">
            <div class="footer-grid">
                <div class="footer-section">
                    <h3>Quick Links</h3>
                    <ul>
                        <li><a href="#">Home</a></li>
                        <li><a href="#">About Us</a></li>
                        <li><a href="#">Services</a></li>
                        <li><a href="#">Contact</a></li>
                    </ul>
                </div>
                <div class="footer-section">
                    <h3>Resources</h3>
                    <ul>
                        <li><a href="#">Tourist Guidelines</a></li>
                        <li><a href="#">Safety Tips</a></li>
                        <li><a href="#">Emergency Contacts</a></li>
                        <li><a href="#">FAQs</a></li>
                    </ul>
                </div>
                <div class="footer-section">
                    <h3>Contact Us</h3>
                    <ul>
                        <li>📞 Toll Free: 1800-XXX-XXXX</li>
                        <li>📧 info@modoner.gov.in</li>
                        <li>📍 New Delhi, India</li>
                    </ul>
                </div>
                <div class="footer-section">
                    <h3>Follow Us</h3>
                    <ul>
                        <li><a href="#">Twitter</a></li>
                        <li><a href="#">Facebook</a></li>
                        <li><a href="#">Instagram</a></li>
                        <li><a href="#">YouTube</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2024 Ministry of Development of North Eastern Region, Government of India</p>
                <p style="margin-top: 8px; font-size: 13px;">Last Updated: January 31, 2026 | Visitors: 1,234,567</p>
            </div>
        </div>
    </footer>
    
    <script>
        function changeFontSize(change) {
            const body = document.body;
            const currentSize = parseInt(window.getComputedStyle(body).fontSize);
            let newSize = currentSize;
            if (change === 1) newSize = Math.min(currentSize + 2, 24);
            else if (change === -1) newSize = Math.max(currentSize - 2, 12);
            else newSize = 16;
            body.style.fontSize = newSize + 'px';
        }
    </script>
</body>
</html>